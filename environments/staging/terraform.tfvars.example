project_name = "aws-terraform-enterprise-platform"
environment  = "staging"
aws_region   = "ap-northeast-1"

vpc_cidr                  = "10.30.0.0/16"
availability_zones        = ["ap-northeast-1a", "ap-northeast-1c"]
public_subnet_cidrs       = ["10.30.0.0/24", "10.30.1.0/24"]
private_app_subnet_cidrs  = ["10.30.10.0/24", "10.30.11.0/24"]
private_db_subnet_cidrs   = ["10.30.20.0/24", "10.30.21.0/24"]

owner       = "platform-team"
cost_center = "learning"
repository  = "aws-terraform-enterprise-platform"

# 安全低成本示例：所有持续计费或外部集成功能默认关闭。
enable_nat_gateway   = false
single_nat_gateway   = true
enable_vpc_endpoints = false
enable_cloudfront    = false
enable_waf           = false
enable_alb           = false
enable_ecs           = false
enable_ec2           = false
enable_rds           = false
enable_rds_multi_az  = false
enable_redis         = false
enable_serverless    = false
enable_cloudtrail    = false
enable_config        = false
enable_guardduty     = false
enable_backup        = false
enable_cicd          = false
enable_github_oidc   = false

ecs_cpu             = 256
ecs_memory          = 512
ecs_desired_count   = 1
instance_type       = "t3.micro"
rds_instance_class  = "db.t4g.micro"
database_name       = "platform"
backup_retention_days = 7
log_retention_days    = 14

# 自定义域名、通知和 GitHub 集成必须由用户显式填写。
domain_name       = null
hosted_zone_id    = null
github_repository = null
alarm_email       = null

